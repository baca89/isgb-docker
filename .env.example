# isGB Docker - Umgebungsvariablen (.env)
# Kopiere diese Datei nach .env und passe die Werte an
# cp .env.example .env

# ========================================
# Grundkonfiguration
# ========================================

# Log-Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Zahl der Worker-Prozesse
WORKERS=4

# Timezone (z.B. Europe/Berlin, America/New_York)
TZ=Europe/Berlin

# ========================================
# Verzeichnisse
# ========================================

# Config-Verzeichnis mit Mailbox-Konfigurationen
CONFIG_DIR=/etc/isgb/mailboxes

# Log-Verzeichnis
LOG_DIR=/var/log/isgb

# Daten-Verzeichnis für Datenbanken
DATA_DIR=/var/lib/isgb

# ========================================
# Spamfilter-Einstellungen
# ========================================

# Globaler Spam-Score Schwellenwert
SPAM_THRESHOLD=5.0

# Maschinelles Lernen aktivieren
ENABLE_LEARNING=true

# Automatisches Lernen aus Spam
AUTO_LEARN_SPAM=true

# Automatisches Lernen aus Nicht-Spam
AUTO_LEARN_HAM=true

# ========================================
# Server/API Einstellungen
# ========================================

# Port für Web-Interface
API_PORT=8080

# API Host
API_HOST=0.0.0.0

# SSL für API (wenn hinter Reverse Proxy)
API_SSL=false

# ========================================
# Performance-Tuning
# ========================================

# Cache-Größe (Anzahl der Einträge)
CACHE_SIZE=1000

# Maximale Anzahl von Nachrichten pro Filter-Run
MAX_MESSAGES_PER_RUN=100

# Timeout für Mail-Server Verbindungen (Sekunden)
CONNECTION_TIMEOUT=30

# ========================================
# Scheduling
# ========================================

# Spam-Check Schedule (cron-format oder Interval)
# Optionen: "hourly", "daily", "every 5 minutes", cron-expression
RUN_SCHEDULE=hourly

# Zeitfenster für automatisches Filtering (HH:MM - HH:MM)
# Leer = immer aktiv
ACTIVE_HOURS=

# ========================================
# Sicherheit
# ========================================

# SSL/TLS Zertifikat validieren bei Mail-Servern
VERIFY_SSL=true

# PII (Personlich Identifiable Information) Detection
DETECT_PII=false

# HTML-Sanitization für Nachrichten
SANITIZE_HTML=true

# ========================================
# Datenbanken
# ========================================

# SQLite Datenbankpfad (lokal im Data-Dir)
# Oder: postgresql://user:pass@localhost:5432/isgb
DATABASE_URL=sqlite:////var/lib/isgb/isgb.db

# Redis Cache (optional)
# Leer = deaktiviert
REDIS_URL=

# ========================================
# Metriken/Monitoring
# ========================================

# Prometheus Metriken exportieren
ENABLE_METRICS=false

# Metriken Port
METRICS_PORT=8081

# ========================================
# Notifications (optional)
# ========================================

# Email für Benachrichtigungen bei Fehlern
NOTIFICATION_EMAIL=

# SMTP Server für Notifications
NOTIFICATION_SMTP_HOST=

NOTIFICATION_SMTP_PORT=587

NOTIFICATION_SMTP_USER=

NOTIFICATION_SMTP_PASSWORD=

# ========================================
# Development/Debug
# ========================================

# Debug-Mode aktivieren
DEBUG=false

# Profiling aktivieren (Performance)
ENABLE_PROFILING=false

# Dry-Run: Teste ohne Änderungen zu machen
DRY_RUN=false
